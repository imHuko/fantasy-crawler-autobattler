; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Fantasy crawler autobattler"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

PlayerInventory="*res://autoloads/player_inventory.gd"
GearGenerator="*res://autoloads/gear_generator.gd"
SaveManager="*res://autoloads/save_manager.gd"
AdminPanel="*res://autoloads/admin_panel.gd"
TutorialOverlay="*res://autoloads/tutorial_overlay.gd"
TutorialRouter="*res://autoloads/tutorial_router.gd"
Telemetry="*res://autoloads/telemetry_manager.gd"
_mcp_game_helper="*res://addons/godot_ai/runtime/game_helper.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_ai/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
textures/vram_compression/import_etc2_astc=true
